#!/bin/bash

set -euo pipefail

interface=$(nmcli -t -f DEVICE,TYPE device status 2>/dev/null | awk -F: '$2 == "wifi" { print $1; exit }')

if [ -z "$interface" ]; then
  printf 'offline\n'
  exit 0
fi

if [ "$(nmcli radio wifi 2>/dev/null | tr '[:upper:]' '[:lower:]')" != "enabled" ]; then
  printf 'off\n'
  exit 0
fi

signal=$(nmcli -t -f ACTIVE,SIGNAL device wifi list ifname "$interface" 2>/dev/null | awk -F: '$1 == "yes" { print $2; exit }')

if [ -n "$signal" ]; then
  printf '%s%%\n' "$signal"
else
  printf 'offline\n'
fi
