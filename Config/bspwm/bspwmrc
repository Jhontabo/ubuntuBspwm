#! /bin/sh

wmname LG3D &
if command -v vmware-user-suid-wrapper >/dev/null 2>&1; then
  vmware-user-suid-wrapper &
fi

pgrep -x sxhkd >/dev/null || sxhkd &

bspc monitor -d I II III IV V VI VII VIII IX X

CURRENT_BORDER='2'
CURRENT_GAP='10'
CURRENT_SRATIO='0.52'

#bspc config border_width         2
#bspc config window_gap          12

bspc config split_ratio 0.52
bspc config borderless_monocle true
bspc config gapless_monocle true

bspc config border_width "$CURRENT_BORDER"
bspc config window_gap "$CURRENT_GAP"
bspc config split_ratio "$CURRENT_SRATIO"
bspc config top_padding 28
bspc config bottom_padding 0
bspc config focused_border_color "#00BFFF"

# HDMI MIRROR
pgrep -af "hdmi_mirror_watch" >/dev/null 2>&1 || \
  nohup "$HOME/.config/bspwm/scripts/hdmi_mirror_watch" >/dev/null 2>&1 &

# WALLPAPER
if [ -f "$HOME/.fehbg" ]; then
  "$HOME/.fehbg" &
elif command -v nitrogen >/dev/null 2>&1; then
  nitrogen --restore &
elif first_wallpaper=$(find "$HOME/Wallpaper" -maxdepth 1 -type f \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' \) | sort | head -n 1); then
  [ -n "$first_wallpaper" ] && feh --bg-fill "$first_wallpaper" &
fi

# POLYBAR
~/.config/polybar/launch.sh

# CUSTOM

# PICOM
PICOM_CFG="$HOME/.config/picom/picom.conf"
PICOM_VM_CFG="$HOME/.config/picom/picom-vm.conf"
PICOM_LOG="$HOME/.cache/picom.log"

mkdir -p "$HOME/.cache"

if command -v systemd-detect-virt >/dev/null 2>&1 && systemd-detect-virt --quiet; then
  if [ -f "$PICOM_VM_CFG" ]; then
    PICOM_CFG="$PICOM_VM_CFG"
  fi
fi

if ! pgrep -x picom >/dev/null 2>&1; then
  picom --config "$PICOM_CFG" --daemon >>"$PICOM_LOG" 2>&1 || \
    picom --backend xrender --config "$PICOM_CFG" --daemon >>"$PICOM_LOG" 2>&1 || true
fi

xsetroot -cursor_name left_ptr &
